# Ключ Pro для пакетной проверки размещений (audit_batch), заголовок X-API-Key.
# Разовые проверки (verify_erid, audit_ad_page, check_compliance_38fz,
# explain_marking_requirement) работают без ключа.
# Получить: https://atomno-mcp.ru/pricing#erid-pro
MCP_ERID_API_KEY=

# Необязательно:
# MCP_ERID_API_BASE=https://api.atomno-mcp.ru/erid
# MCP_ERID_TIMEOUT=30
# MCP_ERID_LOG_LEVEL=INFO
